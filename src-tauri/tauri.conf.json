{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "screenshot-tool",
  "version": "0.1.0",
  "identifier": "com.screenshot-tool.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Screenshot Tool",
        "width": 1024,
        "height": 768,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
